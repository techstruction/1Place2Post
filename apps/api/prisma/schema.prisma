// 1Place2Post Prisma Schema
// Phase 0 → 1 core models: User, SocialAccount, Post, PostPlatform, MediaFile

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Auth & Users
// ─────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  name         String?
  avatarUrl    String?
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  socialAccounts   SocialAccount[]
  posts            Post[]
  mediaFiles       MediaFile[]
  series           Series[]
  linkPages        LinkPage[]
  botRules         BotRule[]
  mediaAssets      MediaAsset[]
  templates        Template[]
  postingSchedules PostingSchedule[]
  engagementEvents EngagementEvent[]
  teamMemberships  TeamMember[]
  rssCampaigns     RssCampaign[]
  outgoingWebhooks OutgoingWebhook[]
  approvals        PostApproval[]
  notifications    Notification[]
  supportTickets   SupportTicket[]
  inboxMessages    InboxMessage[]
  botLogs          BotActionLog[]
  leads            Lead[]
}

enum Role {
  USER
  ADMIN
}

// ─────────────────────────────────────────────
// Social Accounts (OAuth connections)
// ─────────────────────────────────────────────

model SocialAccount {
  id           String    @id @default(cuid())
  userId       String
  platform     Platform
  platformId   String // platform's user/page ID
  username     String?
  displayName  String?
  accessToken  String
  refreshToken String?
  tokenExpiry  DateTime?
  scopes       String[]
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  postPlatforms PostPlatform[]
  inboxMessages InboxMessage[]
  botLogs       BotActionLog[]
  leads         Lead[]
  botRules      BotRule[]

  @@unique([userId, platform, platformId])
}

enum Platform {
  INSTAGRAM
  TIKTOK
  FACEBOOK
  YOUTUBE
  TWITTER
}

// ─────────────────────────────────────────────
// Posts & Scheduling
// ─────────────────────────────────────────────

model Post {
  id                  String     @id @default(cuid())
  userId              String
  title               String?
  caption             String
  hashtags            String[]
  status              PostStatus @default(DRAFT)
  scheduledAt         DateTime?
  publishedAt         DateTime?
  seriesId            String?
  approvalRequestedAt DateTime?
  approvalDecidedAt   DateTime?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  platforms  PostPlatform[]
  mediaFiles PostMedia[]
  approval   PostApproval?
  publishJob PostPublishJob?
  postLogs   PostLog[]
}

enum PostStatus {
  DRAFT
  PENDING_APPROVAL
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
  CANCELLED
  ARCHIVED
}

// ─────────────────────────────────────────────
// Series (post grouping / cadence)
// ─────────────────────────────────────────────

model Series {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  cadence     String? // e.g. "weekly", "daily"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// Link-in-Bio
// ─────────────────────────────────────────────

model LinkPage {
  id            String   @id @default(cuid())
  userId        String
  slug          String   @unique
  title         String
  bio           String?
  avatarUrl     String? // legacy plain URL
  avatarMediaId String? // Phase 4: linked MediaAsset
  themeJson     String   @default("{}") // colors, button style
  contactJson   String   @default("{}") // email, phone, location
  published     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items  LinkItem[]
  clicks LinkClick[]
}

model LinkItem {
  id         String   @id @default(cuid())
  linkPageId String
  label      String
  url        String
  sortOrder  Int      @default(0)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  linkPage LinkPage    @relation(fields: [linkPageId], references: [id], onDelete: Cascade)
  clicks   LinkClick[]
}

model LinkClick {
  id         String   @id @default(cuid())
  linkPageId String
  linkItemId String?
  leadId     String?
  clickedAt  DateTime @default(now())
  ipHash     String? // hashed for privacy

  linkPage LinkPage  @relation(fields: [linkPageId], references: [id], onDelete: Cascade)
  linkItem LinkItem? @relation(fields: [linkItemId], references: [id], onDelete: SetNull)
  lead     Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
}

// ─────────────────────────────────────────────
// Sales Bot Rules
// ─────────────────────────────────────────────

model BotRule {
  id              String       @id @default(cuid())
  userId          String
  name            String
  triggerType     String       @default("comment") // e.g., "comment", "dm"
  platform        Platform?
  socialAccountId String?
  matchType       BotMatchType @default(CONTAINS)
  matchValue      String
  replyMode       String       @default("reply") // e.g., "reply", "dm"
  replyText       String
  webhookUrl      String?
  cooldownSeconds Int          @default(0)
  active          Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  socialAccount SocialAccount? @relation(fields: [socialAccountId], references: [id], onDelete: SetNull)
  logs          BotActionLog[]
}

enum BotMatchType {
  CONTAINS
  REGEX
  ANY
}

model PostPlatform {
  id              String     @id @default(cuid())
  postId          String
  socialAccountId String
  status          PostStatus @default(DRAFT)
  platformPostId  String? // ID returned by the platform after publish
  publishedAt     DateTime?
  errorMessage    String?
  retryCount      Int        @default(0)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  post          Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  socialAccount SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)

  @@unique([postId, socialAccountId])
}

// ─────────────────────────────────────────────
// Media Library
// ─────────────────────────────────────────────

model MediaFile {
  id        String   @id @default(cuid())
  userId    String
  filename  String
  mimeType  String
  sizeBytes Int
  url       String // storage URL (local or cloud)
  tags      String[]
  createdAt DateTime @default(now())

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts PostMedia[]
}

model PostMedia {
  id          String @id @default(cuid())
  postId      String
  mediaFileId String
  sortOrder   Int    @default(0)

  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  mediaFile MediaFile @relation(fields: [mediaFileId], references: [id], onDelete: Cascade)

  @@unique([postId, mediaFileId])
}

// ─────────────────────────────────────────────
// Phase 3: Media Assets (uploaded files)
// TODO: S3 migration — replace urlPath with a signed S3/R2 URL before
// moving beyond MVP to production scale. See implementation_plan.md.
// ─────────────────────────────────────────────

model MediaAsset {
  id           String   @id @default(cuid())
  userId       String
  filename     String // stored filename on disk
  originalName String
  mimeType     String
  sizeBytes    Int
  urlPath      String // e.g. /uploads/filename.jpg
  tags         String[]
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// Phase 3: Templates
// ─────────────────────────────────────────────

model Template {
  id          String    @id @default(cuid())
  userId      String
  name        String
  description String?
  content     String // caption template body
  hashtags    String[]
  platform    Platform? // null = any platform
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// Phase 3: Posting Schedule (preferred times)
// ─────────────────────────────────────────────

model PostingSchedule {
  id        String   @id @default(cuid())
  userId    String
  platform  Platform
  timezone  String   @default("UTC")
  timesJson String // JSON array of "HH:MM" strings

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
}

// ─────────────────────────────────────────────
// Phase 3: Analytics / Engagement Events
// ─────────────────────────────────────────────

model EngagementEvent {
  id         String           @id @default(cuid())
  userId     String
  platform   Platform
  metric     EngagementMetric
  value      Int
  occurredAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum EngagementMetric {
  LIKES
  VIEWS
  COMMENTS
  SHARES
  CLICKS
  FOLLOWERS
}

// ─────────────────────────────────────────────
// Phase 3: Teams
// ─────────────────────────────────────────────

model Team {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members   TeamMember[]
  auditLogs AuditLog[]
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  role      TeamRole @default(MEMBER)
  createdAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
}

// ─────────────────────────────────────────────
// Phase 3: Audit Log
// ─────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  teamId     String?
  entityType String // e.g. "Post", "Template"
  entityId   String?
  action     String // e.g. "created", "deleted"
  metaJson   String   @default("{}")
  createdAt  DateTime @default(now())

  team Team? @relation(fields: [teamId], references: [id], onDelete: SetNull)
}

// ─────────────────────────────────────────────
// Phase 4: Post Approval Workflow
// ─────────────────────────────────────────────

model PostApproval {
  id             String         @id @default(cuid())
  postId         String         @unique
  requestedById  String
  status         ApprovalStatus @default(REQUESTED)
  requestedAt    DateTime       @default(now())
  decidedById    String?
  decidedAt      DateTime?
  decisionReason String?

  post        Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  requestedBy User @relation(fields: [requestedById], references: [id], onDelete: Cascade)
}

enum ApprovalStatus {
  REQUESTED
  APPROVED
  REJECTED
}

// ─────────────────────────────────────────────
// Phase 4: RSS Campaigns
// ─────────────────────────────────────────────

model RssCampaign {
  id              String    @id @default(cuid())
  userId          String
  name            String
  rssUrl          String
  template        String    @default("{{title}} {{link}}")
  socialAccountId String?
  isActive        Boolean   @default(true)
  lastFetchedAt   DateTime?
  lastItemGuid    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// Phase 4: Outgoing Webhooks
// ─────────────────────────────────────────────

model OutgoingWebhook {
  id         String   @id @default(cuid())
  userId     String
  name       String
  url        String
  secret     String?
  eventsJson String   @default("[]") // array of event names to subscribe
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// Phase 5: Publish Queue
// ─────────────────────────────────────────────

model PostPublishJob {
  id          String    @id @default(cuid())
  postId      String    @unique
  status      JobStatus @default(PENDING)
  attempts    Int       @default(0)
  maxAttempts Int       @default(5)
  nextRunAt   DateTime
  lockedAt    DateTime?
  lastError   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([status, nextRunAt])
}

enum JobStatus {
  PENDING
  RUNNING
  RETRY
  SUCCESS
  FAILED
  CANCELLED
}

// ─────────────────────────────────────────────
// Phase 5: Post Logs
// ─────────────────────────────────────────────

model PostLog {
  id        String      @id @default(cuid())
  postId    String
  type      PostLogType @default(INFO)
  message   String
  createdAt DateTime    @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
}

enum PostLogType {
  INFO
  ERROR
}

// ─────────────────────────────────────────────
// Phase 5: Notifications
// ─────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType @default(INFO)
  title     String
  body      String?
  metaJson  String           @default("{}")
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
  PUBLISH_SUCCESS
  PUBLISH_FAILED
  APPROVAL
  SUPPORT
}

// ─────────────────────────────────────────────
// Phase 5: Support Tickets
// ─────────────────────────────────────────────

model SupportTicket {
  id        String       @id @default(cuid())
  userId    String
  subject   String
  status    TicketStatus @default(OPEN)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages SupportMessage[]
}

model SupportMessage {
  id        String        @id @default(cuid())
  ticketId  String
  sender    SupportSender @default(USER)
  message   String
  createdAt DateTime      @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
}

enum TicketStatus {
  OPEN
  CLOSED
}

enum SupportSender {
  USER
  SUPPORT
}

// ─────────────────────────────────────────────
// Phase 6: Unified Inbox & Leads
// ─────────────────────────────────────────────

model InboxMessage {
  id              String    @id @default(cuid())
  userId          String
  socialAccountId String?
  platform        Platform?
  kind            InboxKind @default(DM)
  fromHandle      String?
  message         String
  receivedAt      DateTime  @default(now())
  isRead          Boolean   @default(false)

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  socialAccount SocialAccount? @relation(fields: [socialAccountId], references: [id], onDelete: SetNull)
  botLogs       BotActionLog[]
  leads         Lead[]         @relation("LeadSource")
}

enum InboxKind {
  DM
  COMMENT
}

model Lead {
  id              String     @id @default(cuid())
  userId          String
  socialAccountId String?
  sourceMessageId String?
  handle          String
  status          LeadStatus @default(NEW)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  socialAccount SocialAccount? @relation(fields: [socialAccountId], references: [id], onDelete: SetNull)
  sourceMessage InboxMessage?  @relation("LeadSource", fields: [sourceMessageId], references: [id], onDelete: SetNull)
  linkClicks    LinkClick[]
}

enum LeadStatus {
  NEW
  CLICKED
  CLOSED
}

model BotActionLog {
  id              String   @id @default(cuid())
  botRuleId       String
  userId          String
  socialAccountId String?
  inboxMessageId  String?
  actionTaken     String // e.g., "Replied to DM", "Sent Comment"
  replyText       String?
  createdAt       DateTime @default(now())

  botRule       BotRule        @relation(fields: [botRuleId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  socialAccount SocialAccount? @relation(fields: [socialAccountId], references: [id], onDelete: SetNull)
  inboxMessage  InboxMessage?  @relation(fields: [inboxMessageId], references: [id], onDelete: SetNull)
}
